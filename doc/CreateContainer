# run this somewhere you can afford to have th ollama_storage volume take up ~8GB
docker run -d --gpus=all -v ollama_storage:/root/.ollama -p 11434:11434 --name ollama ollama/ollama

# run llama3.2-vision inside the container
# this will pull the model the first time so it is available when
# JES tries to query it
docker exec -it ollama ollama run llama3.2-vision
